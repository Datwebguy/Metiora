# Environment Configuration
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
HOST=0.0.0.0
API_BASE_URL=https://agentmetiora.xyz

# PostgreSQL & Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metiora?schema=public"

# Redis Cache (Optional — not wired in runtime yet)
REDIS_URL="redis://localhost:6379"

# API security (REQUIRED in production — min 16 chars)
# Protected routes need: x-api-key: <key>  OR  Authorization: Bearer <key>
METIORA_API_KEY=""

# Comma-separated browser origins. Empty in production = no browser CORS (agents/server only).
# Example: https://metiora.ai,https://docs.metiora.ai
CORS_ORIGINS=

# Escrow honesty flag (default true = simulated local DB escrow only)
ESCROW_SIMULATION_MODE=true

# Expose /metrics without API key (default false)
METRICS_PUBLIC=false

# Force API key even outside production
REQUIRE_API_KEY=false

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# AI Provider Credentials (optional — generators currently deterministic)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""

# OKX Marketplace Integration (documented; not all wired to live OKX yet)
OKX_ASP_ID="asp_metiora_v1"
OKX_MARKETPLACE_ENDPOINT="https://api.okx.ai/marketplace/v1"
ONCHAIN_OS_RPC_ENDPOINT="https://rpc.onchainos.org/v1"

# --- OKX Developer Portal (required for x402 HTTP Seller / Facilitator SDK) ---
# Apply: https://web3.okx.com/zh-hans/onchainos/dev-portal
# NEVER commit real values. Use: fly secrets set ...
# Docs: https://web3.okx.com/onchainos/dev-docs/payments/service-seller-sdk
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# X Layer receiving wallet (must match marketplace listing payTo)
PAY_TO_ADDRESS=
# eip155:196 = X Layer mainnet; eip155:1952 = testnet
OKX_PAYMENT_NETWORK=eip155:196
# Official docs map: docs/okx-official-docs-map.md
# APP: https://web3.okx.com/onchainos/dev-docs/payments/app
# SDK: https://web3.okx.com/onchainos/dev-docs/payments/sdk-overview
# A2MCP: https://web3.okx.com/onchainos/dev-docs/okxai/howtomcp

