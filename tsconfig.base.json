{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@metiora/core": ["./packages/core/src"],
      "@metiora/ai": ["./packages/ai/src"],
      "@metiora/memory": ["./packages/memory/src"],
      "@metiora/business-intelligence": ["./packages/business-intelligence/src"],
      "@metiora/conversation": ["./packages/conversation/src"],
      "@metiora/services": ["./packages/services/src"],
      "@metiora/shared": ["./packages/shared/src"],
      "@metiora/database": ["./packages/database/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
