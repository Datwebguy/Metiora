  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  startup  StartupProfile        @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  founder  FounderProfile        @relation(fields: [founderProfileId], references: [id], onDelete: Cascade)
