// ==========================================
// STARTUP HEALTH SERVICE MODELS
// ==========================================

model StartupHealthReportRecord {
  id                 String         @id @default(uuid())
  startupProfileId   String
  founderProfileId   String
  blueprintId        String?
  version            Int            @default(1)
  status             ApprovalStatus @default(PENDING)
  overallScore       Int
  categoryScoresJson Json
  contentJson        Json
  contentMarkdown    String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  startup  StartupProfile             @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  founder  FounderProfile             @relation(fields: [founderProfileId], references: [id], onDelete: Cascade)
  versions StartupHealthReportVersion[]
}

model StartupHealthReportVersion {
  id                 String   @id @default(uuid())
  reportId           String
  versionNumber      Int
  overallScore       Int
  categoryScoresJson Json
  contentJson        Json
  contentMarkdown    String
  changeSummary      String
  createdAt          DateTime @default(now())

  report StartupHealthReportRecord @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, versionNumber])
}

// ==========================================
// OKX.AI ECOSYSTEM INTEGRATION MODELS
// ==========================================

model OkxAgentIdentityRecord {
  id           String   @id @default(uuid())
  agentId      String   @unique
  address      String
  status       String   @default("ACTIVE")
  metadataJson Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OkxWalletSessionRecord {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  sessionToken  String   @unique
  status        String   @default("ACTIVE")
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OkxMarketplaceTaskRecord {
  id                String   @id @default(uuid())
  taskId            String   @unique
  requesterAgentId  String
  founderProfileId  String   @default("")
  startupProfileId  String   @default("")
  serviceType       String
  status            String   @default("RECEIVED")
  scopeJson         Json
  pricingJson       Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OkxNegotiationRecord {
  id               String   @id @default(uuid())
  taskId           String   @unique
  status           String   @default("OPEN")
  proposedPrice    String
  proposedTimeline String
  historyJson      Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OkxEscrowRecord {
  id                String   @id @default(uuid())
  taskId            String   @unique
  escrowId          String   @unique
  amount            String
  status            String   @default("INITIATED")
  arbitrationStatus String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OkxDeliveryRecord {
  id              String   @id @default(uuid())
  taskId          String   @unique
  deliveryId      String   @unique
  contentJson     Json
  contentMarkdown String
  confidenceScore Float
  createdAt       DateTime @default(now())
}

model OkxRatingRecord {
  id             String   @id @default(uuid())
  taskId         String   @unique
  ratingScore    Float
  reviewText     String?
  ratedByAgentId String
  /// ASP / provider agent being rated (not the buyer)
  ratedAgentId   String   @default("metiora-ai-operating-partner")
  createdAt      DateTime @default(now())
}

// ==========================================
// OKX.AI MARKETPLACE REGISTRATION MODELS
// ==========================================

model OkxAspProfileRecord {
  id           String   @id @default(uuid())
  agentName    String   @unique
  displayName  String
  description  String
  category     String
  logoUrl      String
  bannerUrl    String
  websiteUrl   String
  docsUrl      String
  version      String
  metadataJson Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OkxMarketplaceCatalogRecord {
  id                String   @id @default(uuid())
  serviceType       String   @unique
  name              String
  description       String
  capabilitiesJson  Json
  inputSchemaJson   Json
  outputSchemaJson  Json
  pricingJson       Json
  executionModesJson Json
  version           String
  isVerified        Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
