  id              String   @id @default(uuid())
  kitId           String
  versionNumber   Int
  contentJson     Json
  contentMarkdown String
  changeSummary   String
  createdAt       DateTime @default(now())

  kit TokenLaunchKitRecord @relation(fields: [kitId], references: [id], onDelete: Cascade)

  @@unique([kitId, versionNumber])
