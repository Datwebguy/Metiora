  versionNumber   Int
  contentJson     Json
  contentMarkdown String
  changeSummary   String
  createdAt       DateTime @default(now())

  package GrantPackageRecord @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, versionNumber])
